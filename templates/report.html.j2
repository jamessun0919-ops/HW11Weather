<!DOCTYPE html>
<html lang="zh-Hant">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{{ city }} 一週天氣預報</title>
<style>
  .viz-root {
    --surface-1:      #1a1a19;
    --page-plane:      #0d0d0d;
    --text-primary:   #ffffff;
    --text-secondary: #c3c2b7;
    --text-muted:     #898781;
    --gridline:       #2c2c2a;
    --baseline:       #383835;
    --border:         rgba(255,255,255,0.10);
    --series-max:     #e66767; /* categorical slot 6 red, dark step */
    --series-min:     #3987e5; /* categorical slot 1 blue, dark step */
    --series-pop:     #199e70; /* categorical slot 2 aqua, dark step */
  }

  * { box-sizing: border-box; }
  body.viz-root {
    margin: 0;
    background: var(--page-plane);
    color: var(--text-primary);
    font-family: system-ui, -apple-system, "Segoe UI", sans-serif;
  }
  header {
    padding: 28px 24px 12px;
    max-width: 1040px;
    margin: 0 auto;
  }
  header h1 { margin: 0 0 4px; font-size: 28px; font-weight: 600; }
  header p { margin: 0; color: var(--text-secondary); font-size: 14px; }

  main { max-width: 1040px; margin: 0 auto; padding: 12px 24px 48px; }

  .card {
    background: var(--surface-1);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 20px;
    margin-bottom: 20px;
  }
  .card h2 {
    margin: 0 0 14px;
    font-size: 15px;
    font-weight: 600;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: .04em;
  }

  .day-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: 2px;
    background: var(--gridline);
    border-radius: 10px;
    overflow: hidden;
  }
  .day-card {
    background: var(--surface-1);
    padding: 16px 10px;
    text-align: center;
  }
  .day-card .date { font-size: 13px; color: var(--text-secondary); }
  .day-card .icon { font-size: 30px; margin: 6px 0; }
  .day-card .wx { font-size: 12px; color: var(--text-secondary); min-height: 32px; }
  .day-card .temps { font-size: 15px; margin-top: 6px; }
  .day-card .temps .max { color: var(--series-max); font-weight: 600; }
  .day-card .temps .min { color: var(--series-min); }
  .day-card .pop { font-size: 12px; color: var(--series-pop); margin-top: 4px; }

  details summary {
    cursor: pointer;
    color: var(--text-secondary);
    font-size: 13px;
    margin-top: 8px;
  }
  table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 12px;
    font-size: 13px;
  }
  table th, table td {
    text-align: left;
    padding: 8px 10px;
    border-bottom: 1px solid var(--gridline);
    color: var(--text-secondary);
    font-variant-numeric: tabular-nums;
  }
  table th { color: var(--text-muted); font-weight: 500; }

  footer {
    max-width: 1040px;
    margin: 0 auto;
    padding: 0 24px 32px;
    color: var(--text-muted);
    font-size: 12px;
  }

  .crumb-nav {
    max-width: 1040px;
    margin: 0 auto;
    padding: 16px 24px 0;
    font-size: 13px;
  }
  .crumb-nav a {
    color: var(--text-secondary);
    text-decoration: none;
  }
  .crumb-nav a:hover { color: var(--text-primary); text-decoration: underline; }
  .crumb-nav .sep { color: var(--text-muted); margin: 0 6px; }
</style>
</head>
<body class="viz-root">
  {% if back_to_index or back_to_select %}
  <nav class="crumb-nav">
    {% if back_to_index %}<a href="{{ back_to_index }}">🏝️ 地圖首頁</a>{% endif %}
    {% if back_to_index and back_to_select %}<span class="sep">/</span>{% endif %}
    {% if back_to_select %}<a href="{{ back_to_select }}">← 返回選擇地區</a>{% endif %}
  </nav>
  {% endif %}
  <header>
    <h1>{{ city }}｜一週天氣預報</h1>
    <p>資料來源：中央氣象署開放資料平台（未來1週逐12小時天氣預報）・更新時間：{{ update_time }}</p>
  </header>

  <main>
    <div class="card">
      <h2>每日概況</h2>
      <div class="day-row">
        {% for d in days %}
        <div class="day-card">
          <div class="date">{{ d.date_label }}</div>
          <div class="icon">{{ d.icon }}</div>
          <div class="wx">{{ d.wx }}</div>
          <div class="temps"><span class="max">{{ d.max_t | round | int }}°</span> / <span class="min">{{ d.min_t | round | int }}°</span></div>
          <div class="pop">💧 {{ d.pop_pct | round | int }}%</div>
        </div>
        {% endfor %}
      </div>
    </div>

    <div class="card">
      <h2>溫度趨勢</h2>
      {{ temp_chart_html | safe }}
    </div>

    <div class="card">
      <h2>降雨機率</h2>
      {{ pop_chart_html | safe }}
    </div>

    <div class="card">
      <h2>詳細資料</h2>
      <details>
        <summary>展開完整表格（無障礙／原始數值）</summary>
        <table>
          <thead>
            <tr><th>時段</th><th>天氣</th><th>最高溫</th><th>最低溫</th><th>降雨機率</th><th>舒適度</th></tr>
          </thead>
          <tbody>
            {% for r in table_rows %}
            <tr>
              <td>{{ r.period_label }}</td>
              <td>{{ r.wx }}</td>
              <td>{{ r.max_t }}</td>
              <td>{{ r.min_t }}</td>
              <td>{{ r.pop_pct }}</td>
              <td>{{ r.ci }}</td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </details>
    </div>
  </main>

  <footer>
    由 fetch_weather.py 自動產生・資料版權屬中央氣象署所有
  </footer>
</body>
</html>
