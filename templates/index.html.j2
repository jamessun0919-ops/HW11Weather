<!DOCTYPE html>
<html lang="zh-Hant">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>台灣一週天氣預報</title>
<style>
  .viz-root {
    --surface-1:      #1a1a19;
    --page-plane:      #0d0d0d;
    --text-primary:   #ffffff;
    --text-secondary: #c3c2b7;
    --text-muted:     #898781;
    --border:         rgba(255,255,255,0.10);
    --county-fill:    #24344a;
    --county-stroke:  #4a6483;
    --pin:            #3987e5;
    --pin-hot:        #e66767;
  }
  * { box-sizing: border-box; }
  body.viz-root {
    margin: 0;
    background: radial-gradient(ellipse at 50% 0%, #142033 0%, var(--page-plane) 60%);
    color: var(--text-primary);
    font-family: system-ui, -apple-system, "Segoe UI", sans-serif;
    min-height: 100vh;
  }
  header {
    max-width: 720px;
    margin: 0 auto;
    padding: 32px 24px 8px;
    text-align: center;
  }
  header h1 { margin: 0 0 6px; font-size: 26px; font-weight: 600; }
  header p { margin: 0; color: var(--text-secondary); font-size: 14px; }

  .picker {
    max-width: 720px;
    margin: 20px auto 0;
    padding: 0 24px;
    display: flex;
    justify-content: center;
  }
  .picker select {
    background: var(--surface-1);
    color: var(--text-primary);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 10px 14px;
    font-size: 14px;
    min-width: 240px;
  }

  .map-wrap {
    max-width: 560px;
    margin: 24px auto 0;
    padding: 0 24px 48px;
  }
  svg { width: 100%; height: auto; overflow: visible; }
  .county {
    fill: var(--county-fill);
    stroke: var(--county-stroke);
    stroke-width: 1;
    stroke-linejoin: round;
  }

  .pin circle {
    fill: var(--pin);
    stroke: var(--page-plane);
    stroke-width: 2;
    transition: r 0.15s ease;
  }
  .pin:hover circle { r: 7; }
  .pin text {
    fill: var(--text-primary);
    font-size: 11px;
    font-family: system-ui, -apple-system, "Segoe UI", sans-serif;
    pointer-events: none;
  }
  .pin .city-name { font-weight: 600; }
  .pin .city-temp { fill: var(--text-secondary); font-size: 10px; }
  a.pin { cursor: pointer; }

  footer {
    text-align: center;
    color: var(--text-muted);
    font-size: 12px;
    padding: 0 24px 32px;
  }
</style>
</head>
<body class="viz-root">
  <header>
    <h1>台灣一週天氣預報</h1>
    <p>選擇城市查看未來一週天氣預報・資料來源：中央氣象署開放資料平台</p>
  </header>

  <div class="picker">
    <select onchange="if(this.value) location.href=this.value;">
      <option value="">選擇其他縣市…</option>
      {% for c in all_counties %}
      <option value="{{ c.href }}">{{ c.name }}</option>
      {% endfor %}
    </select>
  </div>

  <div class="map-wrap">
    <svg viewBox="{{ viewbox }}" xmlns="http://www.w3.org/2000/svg">
      {% for name, d in county_paths.items() %}
      <path class="county" fill-rule="evenodd" d="{{ d }}" />
      {% endfor %}
      {% for h in headline_cities %}
      <a class="pin" href="{{ h.href }}">
        <circle cx="{{ h.x }}" cy="{{ h.y }}" r="5" />
        <text class="city-name" x="{{ h.x + 10 }}" y="{{ h.y - 4 }}">{{ h.city }}</text>
        <text class="city-temp" x="{{ h.x + 10 }}" y="{{ h.y + 9 }}">{{ h.icon }} {{ h.max_t }}°</text>
      </a>
      {% endfor %}
    </svg>
  </div>

  <footer>由 build_site.py 自動產生・資料版權屬中央氣象署所有</footer>
</body>
</html>
